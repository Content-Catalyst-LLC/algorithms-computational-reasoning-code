    "decision_status_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "termination_guarantee": {"type": "number", "minimum": 0, "maximum": 1},
    "recognizability_status": {"type": "number", "minimum": 0, "maximum": 1},
    "reduction_awareness": {"type": "number", "minimum": 0, "maximum": 1},
    "approximation_honesty": {"type": "number", "minimum": 0, "maximum": 1},
    "automation_scope_clarity": {"type": "number", "minimum": 0, "maximum": 1},
