{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RiskGovernanceAudit",
  "type": "object",
  "required": [
    "risk_id",
    "system",
    "inherent_risk_score",
    "governance_readiness_score",
    "control_effectiveness",
    "residual_risk_score",
    "status"
  ],
  "properties": {
    "risk_id": {
      "type": "string"
    },
    "system": {
      "type": "string"
    },
    "inherent_risk_score": {
      "type": "number"
    },
    "governance_readiness_score": {
      "type": "number"
    },
    "control_effectiveness": {
      "type": "number"
    },
    "residual_risk_score": {
      "type": "number"
    },
    "status": {
      "type": "string"
    }
  }
}
