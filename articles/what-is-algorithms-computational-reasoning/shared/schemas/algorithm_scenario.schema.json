    "decomposition_strength": {"type": "number", "minimum": 0, "maximum": 1},
    "correctness_evidence": {"type": "number", "minimum": 0, "maximum": 1},
    "interpretability": {"type": "number", "minimum": 0, "maximum": 1},
    "robustness": {"type": "number", "minimum": 0, "maximum": 1},
    "governance_readiness": {"type": "number", "minimum": 0, "maximum": 1},
    "data_quality": {"type": "number", "minimum": 0, "maximum": 1},
    "objective_alignment": {"type": "number", "minimum": 0, "maximum": 1},
    "brute_force_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "memory_efficiency": {"type": "number", "minimum": 0, "maximum": 1},
    "monitoring_strength": {"type": "number", "minimum": 0, "maximum": 1}
