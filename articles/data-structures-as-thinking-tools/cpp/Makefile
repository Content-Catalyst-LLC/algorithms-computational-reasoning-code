.PHONY: run clean
run:
	@if command -v c++ >/dev/null 2>&1; then c++ -O2 -std=c++17 data_structure_audit.cpp -o data_structure_audit && mkdir -p ../outputs/tables && ./data_structure_audit > ../outputs/tables/cpp_data_structure_audit.csv; else echo "c++ not found; skipping."; fi
clean:
	rm -f data_structure_audit
