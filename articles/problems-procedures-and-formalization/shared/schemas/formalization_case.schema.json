{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FormalizationCase",
  "type": "object",
  "required": [
    "case_name",
    "real_world_concern",
    "formal_task",
    "input_clarity",
    "output_clarity",
    "constraint_clarity",
    "state_definition",
    "objective_alignment",
    "assumption_documentation",
    "edge_case_handling",
    "stopping_condition_clarity",
    "evaluation_quality",
    "governance_readiness"
  ],
  "properties": {
    "case_name": {"type": "string"},
    "real_world_concern": {"type": "string"},
    "formal_task": {"type": "string"},
    "input_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "output_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "constraint_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "state_definition": {"type": "number", "minimum": 0, "maximum": 1},
    "objective_alignment": {"type": "number", "minimum": 0, "maximum": 1},
    "assumption_documentation": {"type": "number", "minimum": 0, "maximum": 1},
    "edge_case_handling": {"type": "number", "minimum": 0, "maximum": 1},
    "stopping_condition_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "evaluation_quality": {"type": "number", "minimum": 0, "maximum": 1},
    "governance_readiness": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
